<style>
/* Generated service landing — structure styled entirely with Rev.2 tokens */
.gsvc-hero {
  background: var(--ink);
  padding: calc(var(--nav-h) + 72px) 5% 72px;
}
.gsvc-hero-inner { max-width: 1080px; margin: 0 auto; }
.gsvc-eyebrow {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--copper);
  margin-bottom: 18px;
}
.gsvc-h1 {
  font-family: var(--display);
  font-size: clamp(44px, 7vw, 84px);
  line-height: .95;
  letter-spacing: -0.01em;
  color: var(--bone);
  text-transform: uppercase;
  margin-bottom: 20px;
  max-width: 720px;
}
.gsvc-hero p { color: var(--bone); opacity: .8; max-width: 640px; line-height: 1.75; margin-bottom: 14px; }
.gsvc-hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 28px; }

.gsvc-section { padding: 72px 5%; }
.gsvc-section--ink { background: var(--ink); }
.gsvc-inner { max-width: 1080px; margin: 0 auto; }

.gsvc-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; margin-top: 28px; }
.gsvc-list li {
  border: var(--rule-w) solid var(--rule);
  padding: 18px 20px;
  font-size: 14.5px;
  line-height: 1.7;
  background: var(--bone);
}
.gsvc-steps { margin-top: 28px; display: flex; flex-direction: column; gap: 0; counter-reset: step; }
.gsvc-steps li {
  border-top: var(--rule-w) solid var(--rule);
  padding: 20px 0 20px 56px;
  position: relative;
  line-height: 1.7;
  counter-increment: step;
}
.gsvc-steps li::before {
  content: counter(step, decimal-leading-zero);
  position: absolute; left: 0; top: 20px;
  font-family: var(--mono);
  color: var(--copper-deep);
  font-size: 13px;
  letter-spacing: .1em;
}
.gsvc-price {
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--copper-deep);
  margin-top: 24px;
}

.gsvc-gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; margin-top: 28px; }
.gsvc-gallery img { width: 100%; height: 240px; object-fit: cover; }

.gsvc-faq { max-width: 860px; margin: 28px auto 0; }
.faq-item { border-bottom: var(--rule-w) solid var(--rule); }
.faq-item:first-child { border-top: var(--rule-w) solid var(--rule); }
.faq-q {
  width: 100%; background: none; border: none;
  display: flex; align-items: center; justify-content: space-between;
  gap: 20px; padding: 22px 0; cursor: pointer;
  font-family: var(--body); font-size: 16px; font-weight: 600; color: var(--ink);
  text-align: left; transition: color .2s;
}
.faq-q:hover { color: var(--copper-deep); }
.faq-icon { font-size: 26px; color: var(--copper-deep); flex-shrink: 0; line-height: 1; transition: transform .3s ease; }
.faq-item.open .faq-icon { transform: rotate(45deg); }
.faq-a { max-height: 0; overflow: hidden; transition: max-height .4s ease; }
.faq-item.open .faq-a { max-height: 600px; }
.faq-a-inner { padding: 0 0 22px; font-size: 14px; line-height: 1.85; max-width: 720px; }

.gsvc-reviews { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; margin-top: 28px; }
.gsvc-review { border: var(--rule-w) solid var(--rule); padding: 22px; background: var(--bone); }
.gsvc-review-stars { color: var(--copper-deep); letter-spacing: 2px; margin-bottom: 10px; }
.gsvc-review-text { font-size: 14.5px; line-height: 1.75; margin-bottom: 14px; }
.gsvc-review-author { font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }

/* calculator */
.gsvc-calc { border: var(--rule-w) solid var(--rule); padding: 28px; margin-top: 28px; max-width: 640px; }
.gsvc-calc label { display: block; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin: 14px 0 6px; }
.gsvc-calc select, .gsvc-calc input {
  width: 100%; padding: 12px 14px; font-family: var(--body); font-size: 15px;
  border: var(--rule-w) solid var(--rule); background: var(--bone); color: var(--ink);
}
.gsvc-calc-result { display: none; margin-top: 20px; padding: 18px; border: var(--rule-w) solid var(--copper-deep); }
.gsvc-calc-result.show { display: block; }
.gsvc-calc-range { font-family: var(--display); font-size: clamp(28px, 4vw, 44px); color: var(--copper-deep); line-height: 1; }
.gsvc-calc-note { font-size: 12px; color: var(--muted); margin-top: 10px; line-height: 1.6; }

/* quote form */
.gsvc-form { max-width: 640px; margin-top: 28px; }
.gsvc-form .form-row { margin-bottom: 14px; }
.gsvc-form label { display: block; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: rgba(245,244,239,.6); margin-bottom: 6px; }
.gsvc-form input, .gsvc-form textarea {
  width: 100%; padding: 13px 14px; font-family: var(--body); font-size: 15px;
  background: var(--ink-raised); border: var(--rule-w) solid var(--rule); color: var(--bone);
}
.gsvc-form input:focus, .gsvc-form textarea:focus { outline: none; border-color: var(--copper); }
.btn-copper {
  display: inline-block; background: var(--copper); color: var(--ink);
  font-size: 12px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
  padding: 16px 36px; border: none; cursor: pointer; transition: background .2s;
}
.btn-copper:hover { background: var(--copper-light); }
.btn-ghost {
  display: inline-block; background: transparent; color: var(--bone);
  font-size: 12px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
  padding: 15px 32px; border: var(--rule-w) solid var(--rule); transition: border-color .2s;
}
.btn-ghost:hover { border-color: var(--copper); }
.gsvc-section--ink .section-h2, .gsvc-section--ink .section-sub { color: var(--bone); }
</style>
